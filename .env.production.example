POSTGRES_USER=fleetbase
POSTGRES_PASSWORD=change-this-production-password
POSTGRES_DB=fleetbase

# The app container generates DATABASE_URL from POSTGRES_* values at startup.
# Set DATABASE_URL_OVERRIDE=true only if you intentionally want to provide it yourself.
DATABASE_URL_OVERRIDE=false
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
# Öffentliche URL der App (hinter Caddy mit HTTPS = deine Domain).
NEXT_PUBLIC_APP_URL=https://ihre-domain.de
NEXT_ALLOWED_ORIGINS=ihre-domain.de
NEXT_IMAGE_REMOTE_HOSTS=
# Hinter Caddy (HTTPS) auf true setzen, damit Session-Cookies nur über HTTPS gesendet werden.
SESSION_COOKIE_SECURE=true
UPLOAD_STORAGE_DRIVER=local
PASSWORD_RESET_EXPOSE_LINK=false

SUPER_ADMIN_EMAIL=jesse@haemmerle.at
SUPER_ADMIN_NAME=Jesse Haemmerle
SUPER_ADMIN_PASSWORD=
BOOTSTRAP_SUPER_ADMIN=true

# E-Mail-Versand (Resend). Ohne RESEND_API_KEY werden Rechnungs-Mails NICHT
# versendet (Rechnung wird trotzdem finalisiert und kann erneut gesendet werden).
# EMAIL_FROM muss eine bei Resend verifizierte Absenderdomain verwenden.
RESEND_API_KEY=
EMAIL_FROM=Fuhrpark Manager <rechnung@ihre-domain.de>

# Host-Port, auf dem die App lauscht. Caddy reverse-proxyt deine Domain hierauf.
APP_PORT=8082
# HTTP_PORT wird nur vom optionalen nginx-Proxy (Profil "nginx") genutzt.
HTTP_PORT=80
RUN_MIGRATIONS=true
