POSTGRES_USER=fleetbase
POSTGRES_PASSWORD=change-this-production-password
POSTGRES_DB=fleetbase

# The app container generates DATABASE_URL from POSTGRES_* values at startup.
# Set DATABASE_URL_OVERRIDE=true only if you intentionally want to provide it yourself.
DATABASE_URL_OVERRIDE=false
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
NEXT_PUBLIC_APP_URL=http://localhost
NEXT_ALLOWED_ORIGINS=localhost,127.0.0.1
NEXT_IMAGE_REMOTE_HOSTS=
SESSION_COOKIE_SECURE=false
UPLOAD_STORAGE_DRIVER=local

SUPER_ADMIN_EMAIL=jesse@haemmerle.at
SUPER_ADMIN_NAME=Jesse Haemmerle
SUPER_ADMIN_PASSWORD=
BOOTSTRAP_SUPER_ADMIN=true

HTTP_PORT=80
RUN_MIGRATIONS=true
